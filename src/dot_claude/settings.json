{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(du *)",
      "Bash(grep *)",
      "Bash(echo *)",
      "Bash(head *)",
      "Bash(find *)",
      "Bash(git --version)",
      "Bash(git log *)",
      "Bash(git ls-files *)",
      "Bash(git ls-tree *)",
      "Bash(git config --get *)",
      "Bash(git config --list *)",
      "Bash(git check-ignore *)",
      "Bash(git help *)",
      "Bash(git submodule status *)",
      "Bash(git submodule summary *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git clone *)",
      "Bash(git ls-remote *)",
      "Bash(git lfs ls-files *)",
      "Bash(git lfs pull *)",
      "Bash(gh issue view *)",
      "Bash(gh repo view *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh run view *)",
      "Bash(gh run list *)",
      "Bash(gh api repos/*)",
      "Bash(gh api /repos/*)",
      "Bash(gh api 'repos/*)",
      "Bash(gh api \"repos/*)",
      "Bash(gh api graphql *)",
      "Bash(gh search *)",
      "Bash(gh-pr-parse *)",
      "Bash(gh-pr-fetch-reviews *)",
      "Bash(gh-pr-fetch-comments *)",
      "Bash(gh-pr-review-threads *)",
      "Bash(node --version)",
      "Bash(npm view *)",
      "Bash(npm help *)",
      "Bash(claude --version)",
      "Bash(copilot --version)",
      "Bash(copilot --help)",
      "Bash(copilot help *)",
      "Bash(tmux list-windows:*)",
      "Bash(tmux capture-pane:*)",
      "Bash(tmux display-message:*)",
      "Bash(tmux send-keys:*)",
      "Bash(tmux list-panes:*)",
      "Bash(apt-cache policy *)",
      "Bash(lsb_release *)",
      "Bash(~/.claude/r-okm/scripts/*)",
      "Bash(python3 --version)",
      "Bash(python3 ~/.claude/r-okm/scripts/*)",
      "Bash(python3 -m json.tool)",
      "Read(~/.claude/**)",
      "Read(~/.config/zsh/completions/**)",
      "Read(~/.config/tmux/plugins/**)",
      "Read(/tmp/**)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:support.claude.com)",
      "WebFetch(domain:deepwiki.com)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:api.npmjs.org)",
      "WebFetch(domain:docs.npmjs.com)",
      "WebFetch(domain:en.wikipedia.org)",
      "WebFetch(domain:ja.wikipedia.org)",
      "WebFetch(domain:json.schemastore.org)",
      "WebFetch(domain:www.schemastore.org)",
      "WebFetch(domain:zenn.dev)",
      "WebFetch(domain:neovim.io)",
      "WebFetch(domain:vimhelp.org)",
      "WebFetch(domain:www.1password.dev)",
      "Skill(fetch-pr-context)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.config/gh/**)",
      "Read(/mnt/**)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./secrets/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.gnupg/**)",
      "Edit(~/.config/gh/**)",
      "Edit(/mnt/**)",
      "Bash(printenv*)",
      "Bash(env *)",
      "Bash(export *)",
      "Bash(echo $*)",
      "Bash(set *)",
      "Bash(cat /proc*)",
      "Read(~/.zshrc)",
      "Read(~/.bashrc)",
      "Read(~/.zprofile)",
      "Read(/proc/**)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(sudo *)",
      "Bash(git push *)"
    ],
    "ask": [],
    "additionalDirectories": [
      "~/src/github.com/r-okm/project-ignores"
    ]
  },
  "model": "opus[1m]",
  "skillOverrides": {
    "deep-research": "user-invocable-only"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|auth_success|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/r-okm/scripts/notify-claude-activity.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/r-okm/scripts/notify-claude-activity.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/r-okm/scripts/log-permission-request.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/r-okm/scripts/statusline-command.sh"
  },
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "compact-plus@compact-plus-local": true
  },
  "extraKnownMarketplaces": {
    "compact-plus-local": {
      "source": {
        "source": "github",
        "repo": "u-ichi/compact-plus"
      }
    }
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "plansDirectory": "./.ignore/ai/plans",
  "tui": "fullscreen",
  "theme": "dark-ansi"
}
